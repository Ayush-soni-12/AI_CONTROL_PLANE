# hackathon-agent/.env
# Copy this file to .env and fill in your values.
# ⚠️  NEVER use a mainnet wallet private key here — Fuji testnet ONLY.

# Your Fuji testnet wallet private key (get free AVAX at faucet.avax.network)
# This is the AI agent's autonomous payment wallet.
AGENT_PRIVATE_KEY=0xyour_fuji_testnet_private_key_here

# Where NeuralControl control plane is running
CONTROL_PLANE_URL=http://localhost:8000

# Where the demo-service is running
DEMO_SERVICE_URL=http://localhost:3001
