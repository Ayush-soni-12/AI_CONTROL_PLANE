# ─── Copy this to .env on your EC2 ──────────────────────────────────────────
# cp .env.prod.example .env
# nano .env   ← fill in real values

# PostgreSQL
DB_USER=aiuser
DB_PASS=your_strong_db_password
DB_NAME=aicontrolplane

# Redis
REDIS_PASS=your_strong_redis_password

# RabbitMQ
RABBIT_USER=aiuser
RABBIT_PASS=your_strong_rabbit_password

# JWT
SECRET_KEY=your_very_long_random_secret_key_minimum_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email (SMTP)
SMTP_MAIL=your@email.com
SMTP_PASS=your_email_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
