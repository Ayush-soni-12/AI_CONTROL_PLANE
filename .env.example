# ===========================================
# AI Control Plane - Environment Variables
# ===========================================
# Copy this file to .env and fill in your actual values

# DATABASE Configuration
# PostgreSQL connection string
# For local development: use localhost
# For docker-compose: use 'postgres' as hostname
DATABASE_URL=database_url

# REDIS Configuration  
# Redis connection string for caching & real-time data
# For local development: use localhost
# For docker-compose: use 'redis' as hostname
REDIS_URL=redis_url


RABBITMQ_URL=RABBITMQ_URL

# JWT Authentication Configuration
# Secret key for JWT token generation (generate your own!)
# JWT
SECRET_KEY=your_very_long_random_secret_key_minimum_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email (SMTP)
SMTP_MAIL=your@email.com
SMTP_PASS=your_email_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
